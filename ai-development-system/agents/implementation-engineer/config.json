{
  "agent_name": "implementation-engineer",
  "role": "Senior Staff Software Engineer",
  "version": "1.0.0",
  "llm_config": {
    "model": "gemini-2.0-flash",
    "temperature": 0.1,
    "max_output_tokens": 8192
  },
  "workspace_access": {
    "read_directories": [
      "templates",
      "memory",
      "shared_workspace/research",
      "shared_workspace/architecture"
    ],
    "write_directories": [
      "shared_workspace/implementation",
      "src",
      "app",
      "build"
    ]
  },
  "required_outputs": [
    "todo.md",
    "progress.md",
    "completed.md",
    "generated_files.md",
    "implementation_notes.md"
  ]
}
