{
  "agent_name": "solution-architect",
  "role": "Principal Software Architect",
  "version": "1.0.0",
  "llm_config": {
    "model": "gemini-2.0-flash",
    "temperature": 0.2,
    "max_output_tokens": 8192
  },
  "workspace_access": {
    "read_directories": [
      "templates",
      "memory",
      "shared_workspace/research"
    ],
    "write_directories": [
      "shared_workspace/architecture"
    ]
  },
  "required_outputs": [
    "architecture.md",
    "folder_structure.md",
    "implementation_plan.md",
    "module_breakdown.md",
    "api_design.md",
    "database_schema.md",
    "data_flow.md",
    "dependency_graph.md",
    "coding_guidelines.md",
    "milestones.md"
  ]
}
